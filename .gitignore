config.example.js
.DS_Store
node_modules/
www/
*.docx

# iOS — commit the project + config, but not per-user Xcode state or
# build artifacts. Pods is excluded too in case we ever migrate off SPM.
ios/**/xcuserdata/
ios/**/DerivedData/
ios/**/build/
ios/App/Pods/
ios/App/Podfile.lock

# Supabase CLI scratch (not project data)
supabase/.temp/

# Local secrets — service_role keys, etc. Source before running scripts:
#   set -a && source .env && set +a && node scripts/seed-workout-library.js
.env
.env.*
!.env.example

# Apple developer keys — never ship these
App Developer Download/
*.p8
