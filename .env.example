# Local secrets — copy to .env and fill in.
# .env is gitignored. Never commit real values.
#
# Usage for scripts that need the service_role key:
#   set -a && source .env && set +a
#   node scripts/seed-workout-library.js

# Supabase project URL (safe to commit; same as supabase-init.js)
SUPABASE_URL=https://dagdpdcwqdlibxbitdgr.supabase.co

# Supabase service_role key — BYPASSES RLS. Keep local only.
# Rotate at: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_KEY=

# Optional: anon key if a script needs to hit RLS-protected endpoints as a user.
SUPABASE_ANON_KEY=
